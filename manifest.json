{
  "manifest_version": 3,
  "name": "Tick Email Tracker",
  "version": "1.0",
  "description": "Production-ready email tracker SaaS!",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://tick-email-tracker.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Tick Email Tracker"
  }
}